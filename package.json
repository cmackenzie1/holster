{
	"name": "root",
	"private": true,
	"packageManager": "pnpm@10.6.3",
	"scripts": {
		"build": "turbo run build",
		"check-types": "turbo run check-types",
		"deploy": "./scripts/deploy.sh",
		"lint": "biome lint --write ./",
		"format": "biome format --write ./",
		"check": "biome check --write ./",
		"test": "turbo run test",
		"typegen": "turbo run typegen",
		"dev": "turbo run dev",
		"prepare": "husky"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.12",
		"@cloudflare/vitest-pool-workers": "catalog:",
		"@cloudflare/workers-types": "4.20260418.1",
		"husky": "^9.1.7",
		"turbo": "2.9.6",
		"typescript": "6.0.3",
		"vitest": "catalog:"
	},
	"workspaces": {
		"packages": [
			"workers/*",
			"packages/*"
		],
		"catalog": {
			"wrangler": "^4.63.0",
			"@cloudflare/vitest-pool-workers": "^0.12.10",
			"@cloudflare/workers-types": "^4.20260207.0",
			"vitest": "~3.2.4",
			"turbo": "^2.8.3",
			"typescript": "^5.9.3"
		}
	}
}
